{
  "name": "aether",
  "version": "0.2.0",
  "description": "Aether — 世界のニュースを多言語で読み解くデスクトップアプリ",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "build": "npm run build:renderer && npm run build:main && electron-builder",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:icons": "node scripts/build-icons.js",
    "electron": "electron ."
  },
  "keywords": [
    "news",
    "rss",
    "electron",
    "desktop"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "deepl-node": "^1.13.0",
    "dotenv": "^16.4.0",
    "iconv-lite": "^0.6.3",
    "jsdom": "^24.1.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rss-parser": "^3.13.0",
    "sql.js": "^1.12.0"
  },
  "build": {
    "appId": "com.crossoverflyest.aether",
    "productName": "Aether",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "assets/**/*"
    ]
  }
}
